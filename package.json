{
  "name": "ray-finance",
  "version": "0.4.2",
  "description": "Local-first CLI that turns your bank data into a personal AI financial advisor",
  "type": "module",
  "license": "MIT",
  "author": "Clark Dinnison",
  "repository": {
    "type": "git",
    "url": "https://github.com/cdinnison/ray-finance.git"
  },
  "homepage": "https://rayfinance.app",
  "bugs": {
    "url": "https://github.com/cdinnison/ray-finance/issues"
  },
  "keywords": [
    "finance",
    "personal-finance",
    "cli",
    "ai",
    "plaid",
    "budgeting",
    "local-first"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "bin": {
    "ray": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.rmSync('dist/public',{recursive:true,force:true});fs.cpSync('src/public','dist/public',{recursive:true});\"",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "sync": "tsx src/daily-sync.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "inquirer": "^12.0.0",
    "libsql": "^0.5.0",
    "open": "^10.0.0",
    "openai": "^6.34.0",
    "ora": "^8.0.0",
    "plaid": "^28.0.0",
    "react": "^18.3.1",
    "terminal-image": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
